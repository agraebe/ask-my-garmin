# ── Next.js (Vercel) ──────────────────────────────────────────────────────────

# URL of the Python FastAPI backend.
# Local dev:  leave unset (defaults to http://localhost:8000)
# Production: set to your Railway / Render / Fly.io service URL
#   e.g. https://ask-my-garmin-backend.up.railway.app
BACKEND_URL=

# ── Python backend (Railway / local) ─────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com
# Set this in the Railway environment variables (not in Vercel).
ANTHROPIC_API_KEY=sk-ant-...

# Session encryption key — REQUIRED for session tokens to survive server restarts/redeployments.
# Without this, a new random key is generated on every startup and all existing browser sessions
# become invalid, forcing every user to log back in after each deployment.
#
# Generate a key (run once, store the output as this env var):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Set this in Railway environment variables. Never commit the real value.
SESSION_SECRET=

# PostgreSQL connection string for persistent user memory.
# Railway production: use the internal URL (postgres.railway.internal) — only reachable inside Railway's network.
# Local dev: use the Railway TCP proxy public URL (found under PostgreSQL plugin → Connect → Public URL),
#   or a local Postgres instance (e.g. postgresql://postgres:password@localhost:5432/ask_my_garmin).
#   postgres.railway.internal will NOT work from your laptop — connection will silently fail.
# Leave unset to disable memory features entirely (chat still works without it).
#   e.g. postgresql://user:pass@host:5432/dbname
DATABASE_URL=